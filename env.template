# ============================================
# BAND PLATFORM (all 3 agents need these)
# ============================================
BAND_AGENT_ID=your-band-agent-id-here
BAND_API_KEY=your-band-api-key-here

# ============================================
# GROQ (for Whisper transcription)
# ============================================
GROQ_API_KEY=your-groq-api-key-here

# ============================================
# LLM ENDPOINT (swap when API credits available)
# ============================================
# Option A: Groq free tier (current)
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=${GROQ_API_KEY}

# Option B: AIML API (when credits available)
# OPENAI_BASE_URL=https://api.aimlapi.com/v1
# OPENAI_API_KEY=your-aiml-key-here

# Option C: Featherless (when subscribed)
# OPENAI_BASE_URL=https://api.featherless.ai/v1
# OPENAI_API_KEY=your-featherless-key-here

# ============================================
# PIPELINE AGENT IDs (get from Band dashboard)
# ============================================
THUMBNAILER_AGENT_ID=your-thumbnailer-agent-id
EDITOR_AGENT_ID=your-editor-agent-id

# ============================================
# IMAGE GENERATION (optional - uses Pollinations free by default)
# ============================================
# Uncomment to use a paid image API instead
# IMAGE_API_URL=https://api.stability.ai/v2beta/stable-image/generate/sd3
# IMAGE_API_KEY=your-image-api-key
